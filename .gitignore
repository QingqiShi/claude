# Ignore everything by default
*

# Explicitly allow only prompt files
!.gitignore
!CLAUDE.md
!settings.json
!agents/
!agents/**
!skills/
!skills/**
skills/**/.playwright-cli/
skills/**/*.png
skills/**/evals/results/
.DS_Store
!output-styles/
!output-styles/**
!statusline-command.sh
!README.md
!bootstrap.sh
!update.sh

# Third-party skills: reinstalled via bootstrap.sh, never vendored here.
# (Must come after the !skills/** allow-list to override it.)
skills/vercel-cli/
skills/playwright-cli/